<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        x:Class="CSVoom.MainWindow"
        Name="MainWindowElement"
        Title="CSVoom">
    <Grid RowDefinitions="Auto,Auto,Auto,*,Auto">
        <Menu Grid.Row="0">
            <MenuItem Header="Open file" Name="OpenButton" Click="OpenButton_Click" />
            <MenuItem Header="Navigate" Name="NavigateButton" Click="NavigateButton_Click" />
            <MenuItem Header="Command History" Name="CommandHistoryButton" Click="CommandHistoryButton_Click" />
            <MenuItem Header="Settings" Click="SettingsButton_Click" />
        </Menu>
        <StackPanel
            Grid.Row="0"
            Margin="8,8,8,8"
            Orientation="Horizontal"
            HorizontalAlignment="Right"
            Spacing="8">
            <TextBlock
                x:Name="CommandExampleTextBlock"
                HorizontalAlignment="Left"
                Opacity="0.7"
                FontSize="13"
                Text="" />
            <AutoCompleteBox
                x:Name="CommandTextBox"
                PlaceholderText="Command. eg: load, find, hide..."
                FilterMode="Contains"
                KeyDown="CommandTextBox_KeyDown"
                TextChanged="CommandTextBox_TextChanged"
                HorizontalAlignment="Stretch"
                MinWidth="320"
                MinimumPrefixLength="0" />
            <Button Content="Run" Click="RunCommandButton_Click" Name="RunButton" />
        </StackPanel>

        <!-- Inline Panels -->
        <Border Grid.Row="2"
                x:Name="InlinePanelContainer"
                IsVisible="False"
                BorderBrush="Gray"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource SystemControlBackgroundAltHighBrush}">
            <Grid Margin="8">
                <!-- Settings Panel -->
                <StackPanel x:Name="SettingsPanel" IsVisible="False" Spacing="8">
                    <DockPanel>
                        <TextBlock Text="Settings" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" />
                        <Button Content="Close" Click="CloseInlinePanel_Click" HorizontalAlignment="Right" />
                    </DockPanel>
                    <ScrollViewer MaxHeight="400">
                        <StackPanel x:Name="SettingsFieldsContainer" Spacing="8" />
                    </ScrollViewer>
                    <Button Content="Save &amp; Apply" Click="SaveSettings_Click" HorizontalAlignment="Right"
                            Margin="0,8,0,0" />
                </StackPanel>

                <!-- Navigate Panel -->
                <StackPanel x:Name="NavigatePanel" IsVisible="False" Spacing="8">
                    <DockPanel>
                        <TextBlock Text="Navigate" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" />
                        <Button Content="Close" Click="CloseInlinePanel_Click" HorizontalAlignment="Right" />
                    </DockPanel>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Column:" VerticalAlignment="Center" />
                        <AutoCompleteBox x:Name="NavigateColumnBox" Width="200" MinimumPrefixLength="0" FilterMode="Contains" />
                        <TextBlock Text="Row:" VerticalAlignment="Center" />
                        <NumericUpDown x:Name="NavigateRowNumeric" Minimum="1" Value="1" FormatString="N0" />
                        <Button Content="Go" Click="NavigateGo_Click" />
                    </StackPanel>
                </StackPanel>

                <!-- Command History Panel -->
                <StackPanel x:Name="CommandHistoryPanel" IsVisible="False" Spacing="8">
                    <DockPanel>
                        <TextBlock Text="Command History" FontWeight="Bold" FontSize="18" VerticalAlignment="Center" />
                        <Button Content="Close" Click="CloseInlinePanel_Click" HorizontalAlignment="Right" />
                    </DockPanel>
                    <ListBox x:Name="CommandHistoryListBox" MaxHeight="300" SelectionChanged="CommandHistoryListBox_SelectionChanged">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Margin="4" />
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid
            Grid.Row="3"
            x:Name="CsvDataGrid"
            CanUserSortColumns="False"
            AutoGenerateColumns="False"
            IsReadOnly="True"
            GridLinesVisibility="All"
            HeadersVisibility="All" />
        <StackPanel
            Grid.Row="4"
            Orientation="Horizontal">
            <TextBlock
                Margin="8,8,8,8"
                x:Name="StatusTextBlock"
                HorizontalAlignment="Left"
                VerticalAlignment="Bottom"
                FontSize="16"
                Text="Choose a CSV file to display its contents." />
        </StackPanel>
    </Grid>
</Window>